# ---------------------------------------------------------------------------
# Public, client-exposed configuration. These are inlined into the JS bundle
# at build time. Do NOT put secrets here — the BFF intentionally has none.
# ---------------------------------------------------------------------------

NEXT_PUBLIC_APP_NAME="DocInsight AI"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_BASE_URL="/api"

# ---------------------------------------------------------------------------
# Server-only. Optional.
# ---------------------------------------------------------------------------

# Disable Next.js build/runtime telemetry (default: off in our Dockerfile).
# NEXT_TELEMETRY_DISABLED=1
